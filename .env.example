# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ct_analysis

# Model paths
SEGMENTATION_MODEL_PATH=./checkpoints/segmentation/best_model.pt
REGISTRATION_MODEL_PATH=./checkpoints/registration/best_model.pt
CLASSIFIER_MODEL_PATH=./checkpoints/classifier/best_model.pt

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
MIXED_PRECISION=true

# Storage
UPLOAD_DIR=./uploads
RESULTS_DIR=./results

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ct-analysis

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
